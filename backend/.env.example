NODE_ENV=development
PORT=5000

# Development Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=comzilo_db
DB_USER=comzilo_dev
DB_PASSWORD=
DB_POOL_MIN=0
DB_POOL_MAX=10
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000
DB_LOGGING=false
DB_SSL=false

# Test Database Configuration
TEST_DB_HOST=localhost
TEST_DB_PORT=3306
TEST_DB_NAME=comzilo_test
TEST_DB_USER=comzilo_dev
TEST_DB_PASSWORD=
TEST_DB_POOL_MIN=0
TEST_DB_POOL_MAX=5
TEST_DB_POOL_ACQUIRE=30000
TEST_DB_POOL_IDLE=10000

# JWT & Session Configurations
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# General Platform Configs
COOKIE_DOMAIN=localhost
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

BCRYPT_ROUNDS=10

SUPER_ADMIN_EMAIL=admin@comzilo.com
SUPER_ADMIN_PASSWORD=SuperAdminPasswordPlaceholder!
